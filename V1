//Commit 1
#include <Wire.h>
#include "rgb_lcd.h"

// --- GROVE RGB LCD ---
rgb_lcd lcd;

// --- PIN SETUP ---
const int lightSensor = A1;   // LDR/light sensor
const int knob = A0;          // Potentiometer for entering code
const int buzzer = 2;         // Buzzer output pin

// --- ALARM VARIABLES ---
int correctCode = 0;          // Random 3‑digit code
int enteredCode = 0;          // User input from potentiometer

unsigned long lastIncrease = 0;
int beepInterval = 800;       // Time between beeps
int beepPower = 50;           // Buzzer intensity
bool alarmOn = false;

void setup() {
  lcd.begin(16, 2);

  // Set backlight color (R, G, B)
  lcd.setRGB(100, 0, 0);   // Soft blue

  randomSeed(analogRead(A2)); // Random seed from floating pin

  pinMode(buzzer, OUTPUT);

  lcd.print("System Ready");
  delay(1500);
  lcd.clear();
}

void loop() {
  int lightValue = analogRead(lightSensor);

  // --- TRIGGER ALARM WHEN LIGHT IS LOW ---
  if (lightValue < 500 && !alarmOn) {
    startAlarm();
  }

  // --- RUN ALARM ---
  if (alarmOn) {
    readKnob();
    updateBuzzer();
    checkCode();
  }
}

//Commit 2
// ------------------------------------------------------------
// START ALARM
// ------------------------------------------------------------
void startAlarm() {
  alarmOn = true;

  correctCode = random(100, 999); // 3‑digit random code

  lcd.clear();
  lcd.setRGB(255, 0, 0); // Red backlight for alarm
  lcd.print("ALARM TRIGGERED");
  delay(1500);

  lcd.clear();
  lcd.print("Code: ");
  lcd.print(correctCode);
  lcd.setCursor(0, 1);
  lcd.print("Enter: ");
}

// ------------------------------------------------------------
// READ POTENTIOMETER AS USER INPUT
// ------------------------------------------------------------
void readKnob() {
  int knobValue = analogRead(knob);
  enteredCode = map(knobValue, 0, 1023, 0, 999);

  lcd.setCursor(7, 1);
  lcd.print("    "); // clear old digits
  lcd.setCursor(7, 1);
  lcd.print(enteredCode);
}

// ------------------------------------------------------------
// BUZZER GETS LOUDER + FASTER EVERY 10 SECONDS
// ------------------------------------------------------------
void updateBuzzer() {
  unsigned long now = millis();

  tone(buzzer, 1000, 100); // short beep
  delay(beepInterval);

  if (now - lastIncrease > 10000) {
    lastIncrease = now;

    beepInterval = max(100, beepInterval - 100); // faster
    beepPower = min(255, beepPower + 30);        // louder

    analogWrite(buzzer, beepPower);
  }
}
